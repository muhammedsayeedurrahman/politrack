# PolitiTrace AI Configuration
# At least one API key required for AI features to work.
# Without any keys, the system falls back to rule-based analysis.

# Primary (FREE — 15 RPM, 1M tokens/min)
GOOGLE_GENERATIVE_AI_API_KEY=   # Get from https://ai.google.dev

# Fallback 1 (FREE — 1000 req/day)
GROQ_API_KEY=                   # Get from https://console.groq.com

# Optional - Cheap fallback
DEEPSEEK_API_KEY=               # Get from https://platform.deepseek.com

# Optional - Override API base URL (defaults to /api)
# NEXT_PUBLIC_API_URL=
